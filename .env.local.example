NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Oura integration
OURA_CLIENT_ID=your-oura-client-id
OURA_CLIENT_SECRET=your-oura-client-secret
# Secret that authenticates Oura's calls to our webhook endpoint (embedded in
# the registered callback URL + used for the verification handshake). REQUIRED
# for push notifications; webhook setup is skipped if unset. Use a long random
# value — do NOT reuse the client secret.
OURA_WEBHOOK_TOKEN=some-long-random-string
# Public callback for Oura push notifications. Optional on Vercel (derived from
# VERCEL_PROJECT_PRODUCTION_URL); set explicitly for custom domains.
OURA_WEBHOOK_CALLBACK_URL=https://your-app.example.com/api/oura/webhook
